rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedEmail() {
      return request.auth != null
        && request.auth.token.email in [
          "holzer.wolfgang@gmail.com",
          "nawolaju@gmail.com"
        ];
    }

    function isOwnUserPath(userId) {
      return isAllowedEmail() && request.auth.uid == userId;
    }

    match /workspaces/alpine-concierge-tirol/{document=**} {
      allow read, write: if isAllowedEmail();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwnUserPath(userId);
    }
  }
}
